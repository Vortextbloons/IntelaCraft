{
  "name": "@intelacraft/controller",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "test": "npm run build && node --test dist/app.test.js dist/e2e.test.js dist/agent.test.js dist/catalog.test.js"
  },
  "dependencies": {
    "@intelacraft/shared-protocol": "*"
    ,"@intelacraft/pi-extension":"*","@intelacraft/mcp-connection":"*","@intelacraft/construction":"*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
