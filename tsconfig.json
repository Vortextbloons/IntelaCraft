{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "ES2020"
    ],
    "module": "ES2020",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "types": []
  },
  "include": [
    "src/**/*"
  ]
}